#!/bin/bash
# voice-reply - Local TTS using Piper/sherpa-onnx
# Generates OGG Opus audio for Telegram voice notes
#
# Usage: voice-reply "text" [de|en]
#
# Environment variables:
#   SHERPA_ONNX_DIR   - Path to sherpa-onnx installation
#                       Checked in order: $SHERPA_ONNX_DIR,
#                       ~/.local/share/voice-reply/sherpa-onnx, /opt/sherpa-onnx
#   PIPER_VOICES_DIR  - Path to Piper voice models
#                       Checked in order: $PIPER_VOICES_DIR,
#                       ~/.local/share/voice-reply/piper-voices, /opt/piper-voices

set -e

TEXT="$1"
LANG="${2:-auto}"

if [ -z "$TEXT" ]; then
    echo "Usage: voice-reply \"text\" [de|en]"
    echo ""
    echo "Options:"
    echo "  text      Text to convert to speech"
    echo "  language  'de' for German, 'en' for English (default: auto-detect)"
    exit 1
fi

# Resolve sherpa-onnx directory (env var > user-local > system)
if [ -n "$SHERPA_ONNX_DIR" ] && [ -d "$SHERPA_ONNX_DIR" ]; then
    RUNTIME_DIR="$SHERPA_ONNX_DIR"
elif [ -d "$HOME/.local/share/voice-reply/sherpa-onnx" ]; then
    RUNTIME_DIR="$HOME/.local/share/voice-reply/sherpa-onnx"
elif [ -d "/opt/sherpa-onnx" ]; then
    RUNTIME_DIR="/opt/sherpa-onnx"
else
    echo "Error: sherpa-onnx not found. Set SHERPA_ONNX_DIR or run install.sh."
    exit 1
fi

# Resolve voices directory (env var > user-local > system)
if [ -n "$PIPER_VOICES_DIR" ] && [ -d "$PIPER_VOICES_DIR" ]; then
    VOICES_DIR="$PIPER_VOICES_DIR"
elif [ -d "$HOME/.local/share/voice-reply/piper-voices" ]; then
    VOICES_DIR="$HOME/.local/share/voice-reply/piper-voices"
elif [ -d "/opt/piper-voices" ]; then
    VOICES_DIR="/opt/piper-voices"
else
    echo "Error: Piper voices not found. Set PIPER_VOICES_DIR or run install.sh."
    exit 1
fi

OUTPUT_DIR="/tmp/voice-reply-$$"
mkdir -p "$OUTPUT_DIR"

# Auto-detect language if not specified
if [ "$LANG" = "auto" ]; then
    if echo "$TEXT" | grep -qiE '(ä|ö|ü|ß|ich|und|der|die|das|ist|ein|nicht|haben|werden|sein|bitte|danke|guten|hallo|kannst|möchte|würde)'; then
        LANG="de"
    else
        LANG="en"
    fi
fi

# Select voice model based on language
if [ "$LANG" = "de" ]; then
    MODEL_DIR="$VOICES_DIR/vits-piper-de_DE-thorsten-medium"
    MODEL_FILE="de_DE-thorsten-medium.onnx"
else
    MODEL_DIR="$VOICES_DIR/vits-piper-en_US-ryan-high"
    MODEL_FILE="en_US-ryan-high.onnx"
fi

# Verify model exists
if [ ! -d "$MODEL_DIR" ]; then
    echo "Error: Voice model not found at $MODEL_DIR"
    echo "Please download the model first. See SKILL.md for instructions."
    exit 1
fi

# File paths
WAV_FILE="$OUTPUT_DIR/output.wav"
OGG_FILE="/tmp/voice-reply-output.ogg"
TTS_BIN="$RUNTIME_DIR/bin/sherpa-onnx-offline-tts"

# Verify TTS binary exists
if [ ! -x "$TTS_BIN" ]; then
    echo "Error: TTS binary not found at $TTS_BIN"
    echo "Please install sherpa-onnx first. See SKILL.md for instructions."
    exit 1
fi

# Ensure sherpa-onnx shared libraries are findable
export LD_LIBRARY_PATH="$RUNTIME_DIR/lib:${LD_LIBRARY_PATH:-}"

# Run TTS (suppress progress output)
"$TTS_BIN" \
    --vits-model="$MODEL_DIR/$MODEL_FILE" \
    --vits-tokens="$MODEL_DIR/tokens.txt" \
    --vits-data-dir="$MODEL_DIR/espeak-ng-data" \
    --output-filename="$WAV_FILE" \
    "$TEXT" >/dev/null 2>&1

if [ ! -f "$WAV_FILE" ]; then
    echo "Error: Failed to generate audio"
    rm -rf "$OUTPUT_DIR"
    exit 1
fi

# Convert to OGG Opus for Telegram voice notes
# Opus at 48kHz is required for Telegram voice bubbles
ffmpeg -y -i "$WAV_FILE" -c:a libopus -b:a 64k -ar 48000 "$OGG_FILE" 2>/dev/null

# Cleanup temp directory
rm -rf "$OUTPUT_DIR"

# Output for OpenClaw/Telegram
if [ -f "$OGG_FILE" ]; then
    echo "[[audio_as_voice]]"
    echo "MEDIA:$OGG_FILE"
else
    echo "Error: Failed to convert audio to OGG format"
    exit 1
fi
